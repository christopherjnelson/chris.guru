---
// ChatWidget.astro — Floating AI chat widget for "Ziggy"
---

<!-- Floating Action Button -->
<button
  id="chat-fab"
  aria-label="Open chat"
  title="Ziggy is offline"
  class="fixed bottom-6 right-6 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-slate-600 text-white shadow-lg shadow-black/30 transition-all hover:bg-slate-500 hover:scale-105 active:scale-95"
>
  <svg id="chat-icon-open" xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
  </svg>
  <svg id="chat-icon-close" xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
    <line x1="18" y1="6" x2="6" y2="18" />
    <line x1="6" y1="6" x2="18" y2="18" />
  </svg>
</button>

<!-- Chat Window -->
<div
  id="chat-window"
  class="fixed bottom-24 right-6 z-50 hidden w-80 flex-col rounded-2xl border border-slate-800 bg-slate-900 shadow-2xl shadow-black/50 sm:w-96"
>
  <!-- Header -->
  <div class="flex items-center gap-3 border-b border-slate-800 px-4 py-3">
    <div class="relative">
      <div class="flex h-9 w-9 items-center justify-center rounded-full bg-sky-500/20 text-sm font-bold text-sky-400">
        Z
      </div>
      <span id="chat-status-dot" class="absolute -bottom-0.5 -right-0.5 h-3 w-3 rounded-full border-2 border-slate-900 bg-rose-400"></span>
    </div>
    <div>
      <p class="text-sm font-semibold text-slate-100">Ziggy</p>
      <p id="chat-status-text" class="text-xs text-rose-400" aria-live="polite">Offline</p>
    </div>
  </div>

  <!-- Messages -->
  <div id="chat-messages" class="flex-1 space-y-3 overflow-y-auto px-4 py-4" style="max-height: 320px; min-height: 200px;">
    <div class="flex justify-start">
      <div class="max-w-[80%] rounded-2xl rounded-tl-sm bg-slate-800 px-3 py-2 text-sm text-slate-200">
        Hey there! I'm Ziggy, the digital assistant for chris.guru. Ask me about Chris's skills, certifications, projects, or anything else you're curious about!
      </div>
    </div>
  </div>

  <!-- Input -->
  <form id="chat-form" class="border-t border-slate-800 p-3">
    <div class="flex items-center gap-2">
      <input
        id="chat-input"
        type="text"
        placeholder="Chat is currently unavailable"
        autocomplete="off"
        disabled
        class="flex-1 rounded-xl border border-slate-700 bg-slate-800 px-3 py-2 text-sm text-slate-100 placeholder-slate-500 focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500"
      />
      <button
        type="submit"
        id="chat-send"
        aria-label="Send message"
        disabled
        class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-sky-500 text-white transition-colors hover:bg-sky-400 disabled:opacity-50"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13" />
          <polygon points="22 2 15 22 11 13 2 9 22 2" />
        </svg>
      </button>
    </div>
  </form>
</div>

<script>
  import { marked } from 'marked';

  // Configure marked for safe parsing
  marked.setOptions({
    breaks: true, // Convert \n to <br>
    gfm: true, // GitHub-flavored markdown
  });

  const fab = document.getElementById('chat-fab');
  const chatWindow = document.getElementById('chat-window');
  const iconOpen = document.getElementById('chat-icon-open');
  const iconClose = document.getElementById('chat-icon-close');
  const form = document.getElementById('chat-form') as HTMLFormElement | null;
  const input = document.getElementById('chat-input') as HTMLInputElement | null;
  const messages = document.getElementById('chat-messages');
  const sendBtn = document.getElementById('chat-send') as HTMLButtonElement | null;

  // Generate a unique session ID for this chat session
  const sessionId = crypto.randomUUID();

  // Check chatbot availability on page load
  const statusDot = document.getElementById('chat-status-dot');
  const statusText = document.getElementById('chat-status-text');
  let isOnline = false;
  let isSending = false;
  let healthCheckInFlight: Promise<void> | null = null;

  function setAvailability(online: boolean) {
    isOnline = online;

    statusDot?.classList.toggle('bg-emerald-400', online);
    statusDot?.classList.toggle('bg-rose-400', !online);
    statusText?.classList.toggle('text-emerald-400', online);
    statusText?.classList.toggle('text-rose-400', !online);

    if (statusText) statusText.textContent = online ? 'Online' : 'Offline';
    if (input) {
      input.disabled = !online || isSending;
      input.placeholder = online ? 'Type your message...' : 'Chat is currently unavailable';
    }
    if (sendBtn) sendBtn.disabled = !online || isSending;

    fab?.classList.toggle('bg-sky-500', online);
    fab?.classList.toggle('hover:bg-sky-400', online);
    fab?.classList.toggle('shadow-sky-500/30', online);
    fab?.classList.toggle('bg-slate-600', !online);
    fab?.classList.toggle('hover:bg-slate-500', !online);
    fab?.classList.toggle('shadow-black/30', !online);
    fab?.setAttribute('title', `Ziggy is ${online ? 'online' : 'offline'}`);
  }

  async function checkHealth() {
    if (healthCheckInFlight) return healthCheckInFlight;

    healthCheckInFlight = (async () => {
      try {
        const res = await fetch('/api/health', { cache: 'no-store' });
        const data = await res.json();
        setAvailability(res.ok && data.status === 'online');
      } catch {
        setAvailability(false);
      } finally {
        healthCheckInFlight = null;
      }
    })();

    return healthCheckInFlight;
  }

  checkHealth();
  window.setInterval(checkHealth, 60_000);
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) checkHealth();
  });

  // Toggle chat window
  fab?.addEventListener('click', () => {
    chatWindow?.classList.toggle('hidden');
    chatWindow?.classList.toggle('flex');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    if (!isOnline) checkHealth();
    input?.focus();
  });

  // Auto-scroll to bottom
  function scrollToBottom() {
    if (messages) {
      messages.scrollTop = messages.scrollHeight;
    }
  }

  // Sanitize HTML to prevent XSS from markdown output
  function sanitizeHtml(html: string): string {
    const doc = new DOMParser().parseFromString(html, 'text/html');
    const walker = doc.createTreeWalker(doc.body, NodeFilter.SHOW_ELEMENT, null);

    const elementsToRemove: Element[] = [];
    let node: Node | null = walker.currentNode;

    while (node) {
      if (node.nodeType === Node.ELEMENT_NODE) {
        const el = node as Element;

        // Remove script and style tags entirely
        if (el.tagName === 'SCRIPT' || el.tagName === 'STYLE') {
          elementsToRemove.push(el);
        }

        // Strip dangerous attributes (on* event handlers, javascript: URLs)
        for (const attr of Array.from(el.attributes)) {
          if (attr.name.startsWith('on')) {
            el.removeAttribute(attr.name);
          }
          if ((attr.name === 'href' || attr.name === 'src') && attr.value.trim().toLowerCase().startsWith('javascript:')) {
            el.removeAttribute(attr.name);
          }
        }
      }
      node = walker.nextNode();
    }

    elementsToRemove.forEach((el) => el.remove());

    return doc.body.innerHTML;
  }

  // Convert markdown to sanitized HTML
  function renderMarkdown(text: string): string {
    const rawHtml = marked.parse(text) as string;
    return sanitizeHtml(rawHtml);
  }

  // Append a message bubble
  function appendMessage(text: string, sender: 'user' | 'bot') {
    if (!messages) return;

    const wrapper = document.createElement('div');
    wrapper.className = `flex ${sender === 'user' ? 'justify-end' : 'justify-start'}`;

    const bubble = document.createElement('div');
    bubble.className =
      sender === 'user'
        ? 'max-w-[80%] rounded-2xl rounded-tr-sm bg-sky-500 px-3 py-2 text-sm text-white'
        : 'chat-bubble max-w-[80%] rounded-2xl rounded-tl-sm bg-slate-800 px-3 py-2 text-sm text-slate-200';

    // Bot responses: parse markdown to HTML, sanitize, then render.
    // User input: use textContent to prevent XSS.
    if (sender === 'bot') {
      bubble.innerHTML = renderMarkdown(text);
    } else {
      bubble.textContent = text;
    }

    wrapper.appendChild(bubble);
    messages.appendChild(wrapper);
    scrollToBottom();
  }

  // Append typing indicator
  function appendTyping() {
    if (!messages) return null;

    const wrapper = document.createElement('div');
    wrapper.id = 'typing-indicator';
    wrapper.className = 'flex justify-start';

    const bubble = document.createElement('div');
    bubble.className = 'rounded-2xl rounded-tl-sm bg-slate-800 px-4 py-3 text-sm text-slate-400 animate-pulse';
    bubble.textContent = 'Ziggy is typing...';

    wrapper.appendChild(bubble);
    messages.appendChild(wrapper);
    scrollToBottom();

    return wrapper;
  }

  // Form submission
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!input || !sendBtn) return;

    const message = input.value.trim();
    if (!message) return;

    // Append user message instantly
    appendMessage(message, 'user');

    // Clear input and disable send
    input.value = '';
    isSending = true;
    sendBtn.disabled = true;
    input.disabled = true;

    // Show typing indicator
    const typing = appendTyping();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message, sessionId }),
      });

      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.reply || `Chat request failed with ${res.status}`);
      }

      // Remove typing indicator
      typing?.remove();

      // Append Ziggy's reply
      appendMessage(data.reply || 'Hmm, I did not quite catch that.', 'bot');
      setAvailability(true);
    } catch (err) {
      // Remove typing indicator
      typing?.remove();

      // Show error message
      appendMessage('Sorry, something went wrong. Please try again.', 'bot');
      setAvailability(false);
    } finally {
      isSending = false;
      setAvailability(isOnline);
      if (isOnline) input.focus();
    }
  });
</script>

<style is:global>
  /* Markdown formatting styles for chat bubbles */
  .chat-bubble p {
    margin: 0;
  }
  .chat-bubble p + p {
    margin-top: 1.25rem;
  }
  .chat-bubble br {
    display: block;
    margin-top: 0.5rem;
    content: "";
  }
  .chat-bubble ul {
    margin: 0.25rem 0;
    padding-left: 1.25rem;
    list-style-type: disc;
  }
  .chat-bubble ol {
    margin: 0.25rem 0;
    padding-left: 1.25rem;
    list-style-type: decimal;
  }
  .chat-bubble li {
    margin: 0.125rem 0;
  }
  .chat-bubble strong {
    font-weight: 600;
    color: rgb(255 255 255);
  }
  .chat-bubble em {
    font-style: italic;
  }
  .chat-bubble code {
    padding: 0.125rem 0.25rem;
    border-radius: 0.25rem;
    background: rgb(15 23 42);
    font-size: 0.8125rem;
    font-family: ui-monospace, monospace;
    color: rgb(125 211 252);
  }
  .chat-bubble pre {
    margin: 0.5rem 0;
    padding: 0.5rem;
    border-radius: 0.5rem;
    background: rgb(15 23 42);
    overflow-x: auto;
  }
  .chat-bubble pre code {
    padding: 0;
    background: none;
    color: rgb(226 232 240);
  }
  .chat-bubble a {
    color: rgb(56 189 248);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .chat-bubble a:hover {
    color: rgb(125 211 252);
  }
  .chat-bubble h1,
  .chat-bubble h2,
  .chat-bubble h3 {
    font-weight: 600;
    color: rgb(255 255 255);
    margin: 0.5rem 0 0.25rem;
  }
  .chat-bubble h1 {
    font-size: 1rem;
  }
  .chat-bubble h2 {
    font-size: 0.9375rem;
  }
  .chat-bubble h3 {
    font-size: 0.875rem;
  }
  .chat-bubble blockquote {
    margin: 0.25rem 0;
    padding-left: 0.75rem;
    border-left: 2px solid rgb(56 189 248);
    color: rgb(148 163 184);
    font-style: italic;
  }
  .chat-bubble hr {
    margin: 0.5rem 0;
    border: none;
    border-top: 1px solid rgb(51 65 85);
  }
</style>
