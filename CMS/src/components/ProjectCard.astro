---
import type { Repo } from '../types/repo';

interface Props {
  repo: Repo;
}

const { repo } = Astro.props;

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });

const updatedDate = formatDate(repo.updated_at);
const hasDescription = repo.description !== null && repo.description !== '';
const hasLanguage = repo.language !== null && repo.language !== '';
---

<a
  href={repo.html_url}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex flex-col gap-3 rounded-lg border border-slate-800 bg-slate-900/40 p-4 transition-colors hover:border-slate-700 hover:bg-slate-900/60 sm:flex-row sm:items-center sm:gap-5"
>
  <!-- Left: icon + name + description -->
  <div class="flex min-w-0 flex-1 items-start gap-3">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="mt-0.5 flex-shrink-0 text-slate-500 transition-colors group-hover:text-sky-400">
      <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
    </svg>
    <div class="min-w-0">
      <h3 class="text-base font-semibold text-slate-100 transition-colors group-hover:text-sky-400">
        {repo.name}
      </h3>
      {hasDescription && (
        <p class="mt-0.5 truncate text-sm text-slate-400">{repo.description}</p>
      )}
    </div>
  </div>

  <!-- Right: stats -->
  <div class="flex flex-shrink-0 items-center gap-4 text-xs text-slate-500">
    {hasLanguage && (
      <span class="inline-flex items-center gap-1.5">
        <span class="h-2.5 w-2.5 rounded-full bg-sky-400"></span>
        {repo.language}
      </span>
    )}
    <span class="inline-flex items-center gap-1">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279L12 19.446l-7.416 3.967 1.48-8.279L0 9.306l8.332-1.151z" />
      </svg>
      {repo.stargazers_count}
    </span>
    <span class="hidden sm:inline">Updated {updatedDate}</span>
  </div>
</a>