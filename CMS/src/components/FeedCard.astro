---
import type { Post } from '../types/post';

interface Props {
  post: Post;
}

const { post } = Astro.props;

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });

const formattedDate = formatDate(post.date);

// Visual routing: accent colors and labels by type/source
const typeConfig: Record<string, { accent: string; dot: string; label: string }> = {
  achievement: { accent: 'sky', dot: 'bg-sky-400', label: 'Achievement' },
  github_event: { accent: 'purple', dot: 'bg-purple-400', label: 'GitHub' },
  note: { accent: 'slate', dot: 'bg-slate-400', label: 'Note' },
};

const sourceConfig: Record<string, { label: string; badge: string }> = {
  microsoft: { label: 'Microsoft', badge: 'bg-blue-500/10 text-blue-400 border-blue-500/20' },
  okta: { label: 'Okta', badge: 'bg-blue-600/10 text-blue-300 border-blue-600/20' },
  github: { label: 'GitHub', badge: 'bg-purple-500/10 text-purple-400 border-purple-500/20' },
  slack: { label: 'Slack', badge: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' },
};

const typeInfo = typeConfig[post.type] ?? { accent: 'slate', dot: 'bg-slate-400', label: post.type };
const sourceInfo = post.source ? sourceConfig[post.source] ?? { label: post.source, badge: 'bg-slate-500/10 text-slate-400 border-slate-500/20' } : null;

const hasUrl = post.url !== null && post.url !== '';
const hasImage = post.image_url !== null && post.image_url !== '';
const hasTitle = post.title !== null && post.title !== '';
const hasContent = post.content !== null && post.content !== '';
const hasIssuer = post.issuer !== null && post.issuer !== '';
const source = post.source;
---

<div class="relative">
  <span class={`absolute -left-[1.6rem] top-1.5 h-3 w-3 rounded-full ${typeInfo.dot} ring-4 ring-slate-950`} />

  <div
    class={`rounded-lg border p-5 transition-colors ${
      hasUrl
        ? 'border-slate-800 bg-slate-900/40 hover:border-slate-700 hover:bg-slate-900/60'
        : 'border-slate-800 bg-slate-900/40'
    }`}
  >
    <!-- Top row: image/icon + date + source badge -->
    <div class="flex items-start gap-4">
      <!-- Image or fallback icon -->
      {
        hasImage ? (
          <img
            src={post.image_url!}
            alt={post.title ?? 'Post image'}
            class="h-12 w-12 flex-shrink-0 rounded-lg object-cover"
            loading="lazy"
          />
        ) : (
          <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg bg-slate-800/60">
            {source === 'Github' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="text-purple-400">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
              </svg>
            )}
            {source === 'slack' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="text-emerald-400">
                <path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z" />
              </svg>
            )}
            {source === 'microsoft' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="text-blue-400">
                <path d="M11.4 24H0V12.6h11.4V24zM24 24H12.6V12.6H24V24zM11.4 11.4H0V0h11.4v11.4zM24 11.4H12.6V0H24v11.4z" />
              </svg>
            )}
            {source === 'okta' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="text-blue-300">
                <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 18.3a6.3 6.3 0 1 1 0-12.6 6.3 6.3 0 0 1 0 12.6z" />
              </svg>
            )}
            {source !== 'Github' && source !== 'slack' && source !== 'microsoft' && source !== 'okta' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="9" y1="13" x2="15" y2="13" />
                <line x1="9" y1="17" x2="13" y2="17" />
              </svg>
            )}
          </div>
        )
      }

      <div class="min-w-0 flex-1">
        <div class="flex items-center gap-2">
          <p class="text-xs uppercase tracking-wider text-slate-500">{formattedDate}</p>
          {sourceInfo && (
            <span class={`rounded border px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wider ${sourceInfo.badge}`}>
              {sourceInfo.label}
            </span>
          )}
        </div>

        <!-- Title (only if present) -->
        {hasTitle && (
          <h3 class="mt-1 text-lg font-semibold text-slate-100">{post.title}</h3>
        )}

        <!-- Issuer (only if present, e.g., certification issuer) -->
        {hasIssuer && (
          <p class="mt-0.5 text-xs font-medium text-slate-400">{post.issuer}</p>
        )}
      </div>
    </div>

    <!-- Content body (only if present) -->
    {hasContent && (
      <p class="mt-3 text-sm leading-relaxed text-slate-300">{post.content}</p>
    )}

    <!-- Link button (only if URL present) -->
    {
      hasUrl && (
        <a
          href={post.url!}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-sky-400 transition-colors hover:text-sky-300"
        >
          View
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 17L17 7" />
            <path d="M7 7h10v10" />
          </svg>
        </a>
      )
    }
  </div>
</div>
