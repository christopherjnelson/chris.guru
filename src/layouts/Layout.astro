---
import '../styles/global.css';
import ChatWidget from '../components/ChatWidget.astro';

interface Props {
  title?: string;
}

const { title = 'Chris — Portfolio' } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="min-h-screen bg-slate-950 text-slate-100 antialiased dark:bg-slate-950 dark:text-slate-100"
  >
    <header
      class="sticky top-0 z-10 border-b border-slate-800 bg-slate-950/80 backdrop-blur"
    >
      <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-3 text-sm font-semibold tracking-tight text-slate-100">
          <img
            src="/avatar.png"
            alt="Chris"
            width="36"
            height="36"
            class="h-9 w-9 rounded-full object-cover ring-2 ring-sky-400"
          />
          <span>chris<span class="text-sky-400">.guru</span></span>
        </a>
        <ul class="flex items-center gap-6 text-sm text-slate-300">
          <li><a href="/#about" class="hover:text-sky-400">About</a></li>
          <li><a href="/#skills" class="hover:text-sky-400">Skills</a></li>
          <li><a href="/#feed" class="hover:text-sky-400">Feed</a></li>
          <li><a href="/#projects" class="hover:text-sky-400">Projects</a></li>
          <li><a href="/#faq" class="hover:text-sky-400">FAQ</a></li>
        </ul>
      </nav>
    </header>

    <main class="mx-auto max-w-3xl px-6 py-10">
      <slot />
    </main>

    <footer class="mx-auto max-w-3xl px-6 py-8 text-xs text-slate-500">
      <p>&copy; {new Date().getFullYear()} Chris. Built with Astro SSR.</p>
    </footer>
    <ChatWidget />
  </body>
</html>