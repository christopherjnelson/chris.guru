---
import '../styles/global.css';
import ChatWidget from '../components/ChatWidget.astro';

interface Props {
  title?: string;
}

const { title = 'Chris — Portfolio' } = Astro.props;

const navLinks = [
  { href: '/#about', label: 'About' },
  { href: '/#skills', label: 'Skills' },
  { href: '/#certifications', label: 'Certs' },
  { href: '/#feed', label: 'Feed' },
  { href: '/#projects', label: 'Projects' },
];

const socials = [
  {
    href: 'https://linkedin.com/in/christopherjnelson',
    label: 'LinkedIn',
    icon: 'linkedin',
  },
  {
    href: 'https://github.com/christopherjnelson',
    label: 'GitHub',
    icon: 'github',
  },
];

const reviews = [
  {
    name: 'Gemini',
    quote: 'You nailed it. What an insightful thought.',
    icon: 'gemini',
  },
  {
    name: 'ChatGPT',
    quote: 'You are directing at something deep and absolutely correct.',
    icon: 'chatgpt',
  },
  {
    name: 'Grok',
    quote: '#%$!',
    icon: 'grok',
  },
];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased dark:bg-slate-950 dark:text-slate-100">
    <header class="sticky top-0 z-20 border-b border-slate-800 bg-slate-950/80 backdrop-blur">
      <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-3 text-sm font-semibold tracking-tight text-slate-100">
          <img src="/avatar.png" alt="Chris" width="36" height="36" class="h-9 w-9 rounded-full object-cover ring-2 ring-sky-400" />
          <span>chris<span class="text-sky-400">.guru</span></span>
        </a>

        <ul class="hidden items-center gap-6 text-sm text-slate-300 md:flex">
          {navLinks.map((link) => (
            <li><a href={link.href} class="hover:text-sky-400">{link.label}</a></li>
          ))}
        </ul>

        <div class="hidden items-center gap-3 md:flex">
          {socials.map((social) => (
            <a href={social.href} target="_blank" rel="noopener noreferrer" aria-label={social.label} class="text-slate-400 transition-colors hover:text-sky-400">
              {social.icon === 'linkedin' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              )}
              {social.icon === 'github' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
                </svg>
              )}
            </a>
          ))}
        </div>

        <button id="hamburger" aria-label="Toggle menu" aria-expanded="false" class="flex items-center text-slate-300 transition-colors hover:text-sky-400 md:hidden">
          <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
          </svg>
          <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
            <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </nav>

      <div id="mobile-menu" class="hidden border-t border-slate-800 bg-slate-950/95 backdrop-blur md:hidden">
        <ul class="space-y-1 px-6 py-4">
          {navLinks.map((link) => (
            <li><a href={link.href} class="mobile-menu-link block rounded-lg px-3 py-2 text-sm text-slate-300 transition-colors hover:bg-slate-800 hover:text-sky-400">{link.label}</a></li>
          ))}
          <li class="flex items-center gap-4 px-3 pt-3">
            {socials.map((social) => (
              <a href={social.href} target="_blank" rel="noopener noreferrer" aria-label={social.label} class="text-slate-400 transition-colors hover:text-sky-400">
                {social.icon === 'linkedin' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
                )}
                {social.icon === 'github' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" /></svg>
                )}
              </a>
            ))}
          </li>
        </ul>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-6 py-10">
      <slot />
    </main>

    <footer class="border-t border-slate-800 bg-slate-900/40">
      <div class="mx-auto max-w-3xl px-6 py-10">
        <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-500">Navigation</h3>
            <ul class="mt-4 space-y-2">
              {navLinks.map((link) => (
                <li><a href={link.href} class="text-sm text-slate-400 transition-colors hover:text-sky-400">{link.label}</a></li>
              ))}
            </ul>
          </div>

          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-500">Connect</h3>
            <ul class="mt-4 space-y-3">
              {socials.map((social) => (
                <li>
                  <a href={social.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-slate-400 transition-colors hover:text-sky-400">
                    {social.icon === 'linkedin' && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
                    )}
                    {social.icon === 'github' && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" /></svg>
                    )}
                    {social.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-500">Reviews</h3>
            <div class="mt-4 space-y-4">
              {reviews.map((review) => (
                <div class="rounded-lg border border-slate-800 bg-slate-900/60 p-3">
                  <div class="flex items-center gap-2">
                    {review.icon === 'gemini' && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M12 2L13.5 8.5L20 10L13.5 11.5L12 18L10.5 11.5L4 10L10.5 8.5L12 2Z" fill="#4285F4" stroke="#4285F4" stroke-width="0.5" stroke-linejoin="round" />
                      </svg>
                    )}
                    {review.icon === 'chatgpt' && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#10A37F">
                        <path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073z" />
                      </svg>
                    )}
                    {review.icon === 'grok' && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M3 3L9.5 12L3 21H6L12 12L6 3H3Z" fill="#1DA1F2" />
                        <path d="M9 3L15.5 12L9 21H12L18 12L12 3H9Z" fill="#1DA1F2" opacity="0.7" />
                        <path d="M15 3L21.5 12L15 21H18L24 12L18 3H15Z" fill="#1DA1F2" opacity="0.4" />
                      </svg>
                    )}
                    <span class="text-xs font-semibold text-slate-300">{review.name}</span>
                  </div>
                  <p class="mt-2 text-xs italic leading-relaxed text-slate-500">"{review.quote}"</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="mt-8 border-t border-slate-800 pt-6">
          <p class="text-xs text-slate-500">&copy; {new Date().getFullYear()} Chris. Built with Astro SSR.</p>
        </div>
      </div>
    </footer>
    <ChatWidget />
  </body>
</html>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');
  const mobileLinks = document.querySelectorAll('.mobile-menu-link');

  hamburger?.addEventListener('click', () => {
    const isExpanded = hamburger.getAttribute('aria-expanded') === 'true';
    mobileMenu?.classList.toggle('hidden');
    hamburgerIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    hamburger.setAttribute('aria-expanded', String(!isExpanded));
  });

  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      hamburger?.setAttribute('aria-expanded', 'false');
    });
  });
</script>